{
  "properties": {
    "apiVersion": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    },
    "spec": {
      "additionalProperties": false,
      "properties": {
        "artifacts": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "copy": {
                "items": {
                  "additionalProperties": false,
                  "properties": {
                    "exclude": {
                      "items": {
                        "type": "string"
                      },
                      "maxItems": 100,
                      "type": "array"
                    },
                    "from": {
                      "maxLength": 1024,
                      "minLength": 1,
                      "pattern": "^@([a-z0-9]([a-z0-9_-]*[a-z0-9])?)/(.*)$",
                      "type": "string"
                    },
                    "strategy": {
                      "enum": [
                        "Overwrite",
                        "Merge",
                        "Extract"
                      ],
                      "type": "string"
                    },
                    "to": {
                      "maxLength": 1024,
                      "minLength": 1,
                      "pattern": "^@(artifact)/(.*)$",
                      "type": "string"
                    }
                  },
                  "required": [
                    "from",
                    "to"
                  ],
                  "type": "object"
                },
                "minItems": 1,
                "type": "array"
              },
              "name": {
                "maxLength": 253,
                "minLength": 1,
                "type": "string"
              },
              "originRevision": {
                "maxLength": 64,
                "pattern": "^@([a-z0-9]([a-z0-9_-]*[a-z0-9])?)$",
                "type": "string"
              },
              "revision": {
                "maxLength": 64,
                "pattern": "^@([a-z0-9]([a-z0-9_-]*[a-z0-9])?)$",
                "type": "string"
              }
            },
            "required": [
              "copy",
              "name"
            ],
            "type": "object"
          },
          "maxItems": 1000,
          "minItems": 1,
          "type": "array"
        },
        "commonMetadata": {
          "additionalProperties": false,
          "properties": {
            "annotations": {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            "labels": {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            }
          },
          "type": "object"
        },
        "pathPattern": {
          "maxLength": 1024,
          "pattern": "^@([a-z0-9]([a-z0-9_-]*[a-z0-9])?)/(.*)$",
          "type": "string"
        },
        "sources": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "alias": {
                "maxLength": 63,
                "pattern": "^[a-z0-9]([a-z0-9_-]*[a-z0-9])?$",
                "type": "string"
              },
              "kind": {
                "enum": [
                  "Bucket",
                  "GitRepository",
                  "OCIRepository",
                  "HelmChart",
                  "ExternalArtifact"
                ],
                "type": "string"
              },
              "name": {
                "maxLength": 253,
                "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$",
                "type": "string"
              },
              "namespace": {
                "maxLength": 63,
                "minLength": 1,
                "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
                "type": "string"
              }
            },
            "required": [
              "alias",
              "kind",
              "name"
            ],
            "type": "object"
          },
          "maxItems": 1000,
          "minItems": 1,
          "type": "array"
        }
      },
      "required": [
        "artifacts",
        "sources"
      ],
      "type": "object",
      "x-kubernetes-validations": [
        {
          "message": "artifact names must be valid Kubernetes object names when pathPattern is not set",
          "rule": "has(self.pathPattern) && size(self.pathPattern) > 0 || self.artifacts.all(a, a.name.matches('^[a-z0-9]([-a-z0-9]*[a-z0-9])?(\\\\.[a-z0-9]([-a-z0-9]*[a-z0-9])?)*$'))"
        }
      ]
    },
    "status": {
      "additionalProperties": false,
      "properties": {
        "conditions": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "lastTransitionTime": {
                "format": "date-time",
                "type": "string"
              },
              "message": {
                "maxLength": 32768,
                "type": "string"
              },
              "observedGeneration": {
                "format": "int64",
                "minimum": 0,
                "type": "integer"
              },
              "reason": {
                "maxLength": 1024,
                "minLength": 1,
                "pattern": "^[A-Za-z]([A-Za-z0-9_,:]*[A-Za-z0-9_])?$",
                "type": "string"
              },
              "status": {
                "enum": [
                  "True",
                  "False",
                  "Unknown"
                ],
                "type": "string"
              },
              "type": {
                "maxLength": 316,
                "pattern": "^([a-z0-9]([-a-z0-9]*[a-z0-9])?(\\.[a-z0-9]([-a-z0-9]*[a-z0-9])?)*/)?(([A-Za-z0-9][-A-Za-z0-9_.]*)?[A-Za-z0-9])$",
                "type": "string"
              }
            },
            "required": [
              "lastTransitionTime",
              "message",
              "reason",
              "status",
              "type"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "inventory": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "digest": {
                "type": "string"
              },
              "filename": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "namespace": {
                "type": "string"
              }
            },
            "required": [
              "digest",
              "filename",
              "name",
              "namespace"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "lastHandledReconcileAt": {
          "type": "string"
        },
        "observedSourcesDigest": {
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "type": "object"
}
